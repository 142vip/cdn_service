{
  "name": "@142vip/cdn-service",
  "type": "module",
  "version": "0.0.1-alpha.2",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "description": "142vip平台相关cdn业务，提供静态资源加速访问服务",
  "author": {
    "name": "微信公众号：储凡",
    "email": "fairy_vip@2925.com",
    "url": "https://github.com/142vip",
    "homePage": "https://142vip.cn"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/142vip/cdn_service"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm && chmod 777 ./scripts/*",
    "postinstall": "simple-git-hooks",
    "clean": "npx fa clean --dist --deps --all --ignore-tips",
    "clean:hooks": "npx fa clean --git-hooks --all --ignore-tips",
    "lint": "npx fa lint",
    "lint:fix": "npx fa lint --fix",
    "release": "npx fa release --vip",
    "dev:site": "pnpm -C site exec vite",
    "build:site": "pnpm -C site exec vue-tsc --noEmit && pnpm -C site exec vite build",
    "preview:site": "pnpm -C site exec vite preview"
  },
  "devDependencies": {
    "@142vip/changelog": "0.0.1-alpha.23",
    "@142vip/commit-linter": "0.0.1-alpha.2",
    "@142vip/eslint-config": "0.0.1-alpha.5",
    "@142vip/fairy-cli": "0.0.3-alpha.30",
    "@142vip/utils": "0.0.1-alpha.50",
    "@types/node": "22.10.7",
    "only-allow": "1.2.1",
    "simple-git-hooks": "2.13.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint:fix",
    "commit-msg": "npx node --loader ts-node/esm --no-warnings scripts/core/verify-commit.ts"
  }
}
