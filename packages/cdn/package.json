{
  "name": "@142vip/cdn",
  "type": "module",
  "version": "0.0.1-alpha.0",
  "description": "142vip CDN 静态资源与 URL 工具（media / vip-main JSON + getCdnUrl）",
  "author": "142vip",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/142vip/cdn_service",
    "directory": "packages/cdn"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./media/*": "./assets/media/*",
    "./vip-main/*": "./assets/vip-main/*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "assets",
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
